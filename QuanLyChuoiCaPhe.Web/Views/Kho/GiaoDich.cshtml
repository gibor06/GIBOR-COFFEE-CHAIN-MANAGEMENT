@model KhoGiaoDichViewModel
@{
    ViewData["Title"] = "Giao dịch Kho";
}

<div class="container-fluid p-4">
    <h2><i class="bi bi-arrow-left-right"></i> Giao dịch Kho</h2>

    <div class="card mt-3">
        <div class="card-body">
            <form asp-action="GiaoDich" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Chi nhánh</label>
                        <select asp-for="MaChiNhanh" class="form-select" asp-items="ViewBag.ChiNhanhs"></select>
                        <span asp-validation-for="MaChiNhanh" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nguyên liệu</label>
                        <select asp-for="MaNguyenLieu" class="form-select" asp-items="ViewBag.NguyenLieus"></select>
                        <span asp-validation-for="MaNguyenLieu" class="text-danger"></span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Loại giao dịch</label>
                        <select asp-for="LoaiGiaoDich" class="form-select">
                            <option value="">-- Chọn loại --</option>
                            <option value="Nhập">Nhập</option>
                            <option value="Xuất">Xuất</option>
                            <option value="Hao hụt">Hao hụt</option>
                            <option value="Hết hạn">Hết hạn</option>
                        </select>
                        <span asp-validation-for="LoaiGiaoDich" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Số lượng</label>
                        <input asp-for="SoLuong" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="SoLuong" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Ghi chú</label>
                    <textarea asp-for="GhiChu" class="form-control" rows="3"></textarea>
                </div>
                <button type="submit" class="btn btn-coffee">
                    <i class="bi bi-save"></i> Ghi nhận
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-circle"></i> Hủy
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
