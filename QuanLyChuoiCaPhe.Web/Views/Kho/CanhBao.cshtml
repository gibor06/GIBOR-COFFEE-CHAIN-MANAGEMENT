@model IEnumerable<VwCanhBaoTonKho>
@{
    ViewData["Title"] = "Cảnh báo Tồn kho";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-exclamation-triangle"></i> Cảnh báo Tồn kho</h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <strong>Có @Model.Count() nguyên liệu cần cảnh báo!</strong>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Chi nhánh</th>
                                <th>Nguyên liệu</th>
                                <th>Số lượng tồn</th>
                                <th>Mức cảnh báo</th>
                                <th>Mức độ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="table-warning">
                                    <td>@item.TenChiNhanh</td>
                                    <td><strong>@item.TenNguyenLieu</strong></td>
                                    <td class="text-danger">@item.SoLuongTon?.ToString("N2")</td>
                                    <td>@item.MucCanhBao?.ToString("N2")</td>
                                    <td>
                                        <span class="badge bg-danger">@item.MucDo</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <strong>Tuyệt vời!</strong> Không có nguyên liệu nào cần cảnh báo.
        </div>
    }
</div>
