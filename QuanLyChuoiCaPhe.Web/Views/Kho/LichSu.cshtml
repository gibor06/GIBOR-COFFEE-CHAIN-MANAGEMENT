@model IEnumerable<LichSuKho>
@{
    ViewData["Title"] = "Lịch sử Kho";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-clock-history"></i> Lịch sử Giao dịch Kho</h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <select name="chiNhanh" class="form-select">
                        <option value="">-- Tất cả chi nhánh --</option>
                        @foreach (var cn in ViewBag.ChiNhanhs as List<ChiNhanh>)
                        {
                            <option value="@cn.MaChiNhanh" selected="@(ViewBag.ChiNhanh == cn.MaChiNhanh)">@cn.TenChiNhanh</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="date" name="tuNgay" class="form-control" value="@ViewBag.TuNgay" />
                </div>
                <div class="col-md-3">
                    <input type="date" name="denNgay" class="form-control" value="@ViewBag.DenNgay" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Lọc
                    </button>
                    <a asp-action="LichSu" class="btn btn-secondary">
                        <i class="bi bi-arrow-clockwise"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Thời gian</th>
                            <th>Loại GD</th>
                            <th>Chi nhánh</th>
                            <th>Nguyên liệu</th>
                            <th>Số lượng</th>
                            <th>Ghi chú</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ThoiGian.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.LoaiGiaoDich == "Nhập")
                                    {
                                        <span class="badge bg-success">@item.LoaiGiaoDich</span>
                                    }
                                    else if (item.LoaiGiaoDich == "Xuất")
                                    {
                                        <span class="badge bg-primary">@item.LoaiGiaoDich</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@item.LoaiGiaoDich</span>
                                    }
                                </td>
                                <td>@item.MaChiNhanh</td>
                                <td>@item.MaNguyenLieu</td>
                                <td><strong>@item.SoLuong.ToString("N2")</strong></td>
                                <td>@item.GhiChu</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
