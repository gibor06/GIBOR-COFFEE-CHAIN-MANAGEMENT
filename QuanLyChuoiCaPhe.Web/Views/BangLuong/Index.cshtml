@model IEnumerable<VwBangLuongTongHop>
@{
    ViewData["Title"] = "Quản lý Bảng lương";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-cash-stack"></i> Quản lý Bảng lương</h2>
        @if (ViewBag.IsAdmin || ViewBag.CurrentVaiTro == "KE_TOAN")
        {
            <a asp-action="KhoiTao" class="btn btn-coffee">
                <i class="bi bi-plus-circle"></i> Khởi tạo lương
            </a>
        }
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <select name="thang" class="form-select">
                        <option value="">-- Tất cả tháng --</option>
                        @for (byte i = 1; i <= 12; i++)
                        {
                            <option value="@i" selected="@(ViewBag.Thang == i)">Tháng @i</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <select name="nam" class="form-select">
                        <option value="">-- Tất cả năm --</option>
                        @for (short i = 2024; i <= 2030; i++)
                        {
                            <option value="@i" selected="@(ViewBag.Nam == i)">Năm @i</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Lọc
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-clockwise"></i> Làm mới
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Mã NV</th>
                            <th>Nhân viên</th>
                            <th>Chi nhánh</th>
                            <th>Tháng/Năm</th>
                            <th>Tổng giờ</th>
                            <th>Lương ca</th>
                            <th>Thưởng</th>
                            <th>Khấu trừ</th>
                            <th>Thực lãnh</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MaNV</td>
                                <td><strong>@item.HoTenNV</strong></td>
                                <td>@item.TenChiNhanh</td>
                                <td>@item.Thang/@item.Nam</td>
                                <td>@item.TongGioThucTe?.ToString("N2")</td>
                                <td>@item.TongLuongCa?.ToString("N0") đ</td>
                                <td>@item.TongThuong?.ToString("N0") đ</td>
                                <td class="text-danger">@item.TongKhauTru?.ToString("N0") đ</td>
                                <td class="text-success"><strong>@item.ThucLanh?.ToString("N0") đ</strong></td>
                                <td>
                                    @if (item.TrangThai == "Đã thanh toán")
                                    {
                                        <span class="badge bg-success">Đã thanh toán</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Tạm tính</span>
                                    }
                                </td>
                                <td>
                                    @if (item.TrangThai == "Tạm tính" && (ViewBag.IsAdmin || ViewBag.CurrentVaiTro == "KE_TOAN"))
                                    {
                                        <button type="button" class="btn btn-sm btn-success" onclick="xacNhanThanhToan('@item.MaNV', @item.Thang, @item.Nam)">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function xacNhanThanhToan(maNV, thang, nam) {
            if (confirm('Xác nhận đã thanh toán lương cho nhân viên này?')) {
                fetch('/BangLuong/XacNhanThanhToan?maNV=' + maNV + '&thang=' + thang + '&nam=' + nam, { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showToast(data.message, 'success');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast(data.message, 'error');
                    }
                });
            }
        }
    </script>
}
