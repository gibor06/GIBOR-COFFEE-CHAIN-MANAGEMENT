@model IEnumerable<ChiNhanh>
@{
    ViewData["Title"] = "Quản lý Chi nhánh";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-shop"></i> Quản lý Chi nhánh</h2>
        @if (ViewBag.IsAdmin)
        {
            <a asp-action="Create" class="btn btn-coffee">
                <i class="bi bi-plus-circle"></i> Thêm chi nhánh
            </a>
        }
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <input type="text" name="search" class="form-control" placeholder="Tìm kiếm..." value="@ViewBag.Search" />
                </div>
                <div class="col-md-3">
                    <select name="khuVuc" class="form-select">
                        <option value="">-- Tất cả khu vực --</option>
                        @foreach (var kv in ViewBag.KhuVucs as List<KhuVuc>)
                        {
                            <option value="@kv.MaKhuVuc" selected="@(ViewBag.KhuVuc == kv.MaKhuVuc)">@kv.TenKhuVuc</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="trangThai" class="form-select">
                        <option value="">-- Tất cả trạng thái --</option>
                        <option value="true" selected="@(ViewBag.TrangThai == true)">Đang hoạt động</option>
                        <option value="false" selected="@(ViewBag.TrangThai == false)">Ngừng hoạt động</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Tìm kiếm
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-clockwise"></i> Làm mới
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Mã</th>
                            <th>Tên chi nhánh</th>
                            <th>Khu vực</th>
                            <th>Số điện thoại</th>
                            <th>Địa chỉ</th>
                            <th>Ngày thành lập</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MaChiNhanh</td>
                                <td>@item.TenChiNhanh</td>
                                <td>@item.KhuVuc.TenKhuVuc</td>
                                <td>@item.SoDienThoai</td>
                                <td>@item.DiaChi</td>
                                <td>@item.NgayThanhLap.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.TrangThai)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Ngừng</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.MaChiNhanh" class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (ViewBag.IsAdmin)
                                    {
                                        <button type="button" class="btn btn-sm btn-warning" onclick="toggleStatus('@item.MaChiNhanh')">
                                            <i class="bi bi-toggle-on"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleStatus(id) {
            if (confirm('Bạn có chắc muốn thay đổi trạng thái?')) {
                fetch('/ChiNhanh/ToggleStatus?id=' + id, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showToast(data.message, 'success');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast(data.message, 'error');
                    }
                });
            }
        }
    </script>
}
