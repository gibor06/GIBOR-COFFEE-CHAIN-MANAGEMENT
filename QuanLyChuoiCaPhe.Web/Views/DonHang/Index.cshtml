@model IEnumerable<DonHang>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-receipt"></i> Quản lý Đơn hàng</h2>
        <a asp-action="Create" class="btn btn-coffee">
            <i class="bi bi-plus-circle"></i> Tạo đơn hàng
        </a>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <input type="text" name="search" class="form-control" placeholder="Mã đơn hàng..." value="@ViewBag.Search" />
                </div>
                <div class="col-md-3">
                    <input type="date" name="tuNgay" class="form-control" value="@ViewBag.TuNgay" />
                </div>
                <div class="col-md-3">
                    <input type="date" name="denNgay" class="form-control" value="@ViewBag.DenNgay" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Tìm kiếm
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-clockwise"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Mã ĐH</th>
                            <th>Chi nhánh</th>
                            <th>Nhân viên</th>
                            <th>Khách hàng</th>
                            <th>Tổng tiền</th>
                            <th>Giảm giá</th>
                            <th>Thành tiền</th>
                            <th>PTTT</th>
                            <th>Ngày tạo</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.MaDH</strong></td>
                                <td>@item.ChiNhanh.TenChiNhanh</td>
                                <td>@item.ThongTinNhanVien.HoTenNV</td>
                                <td>@(item.KhachHang?.TenKH ?? "Vãng lai")</td>
                                <td>@item.TongTien.ToString("N0") đ</td>
                                <td>@item.GiamGia.ToString("N0") đ</td>
                                <td class="text-success"><strong>@((item.TongTien - item.GiamGia).ToString("N0")) đ</strong></td>
                                <td>@item.PhuongThucThanhToan</td>
                                <td>@item.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.TrangThai == "Khởi tạo")
                                    {
                                        <span class="badge bg-secondary">@item.TrangThai</span>
                                    }
                                    else if (item.TrangThai == "Hoàn tất")
                                    {
                                        <span class="badge bg-success">@item.TrangThai</span>
                                    }
                                    else if (item.TrangThai == "Hủy")
                                    {
                                        <span class="badge bg-danger">@item.TrangThai</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">@item.TrangThai</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.MaDH" class="btn btn-sm btn-info" title="Chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        
                                        @if (item.TrangThai != "Hoàn tất" && item.TrangThai != "Hủy")
                                        {
                                            <div class="btn-group" role="group">
                                                <button type="button" class="btn btn-sm btn-secondary dropdown-toggle" data-bs-toggle="dropdown" title="Cập nhật trạng thái">
                                                    <i class="bi bi-arrow-repeat"></i>
                                                </button>
                                                <ul class="dropdown-menu">
                                                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="capNhatTrangThai('@item.MaDH', 'Hoàn tất')">Hoàn tất</a></li>
                                                </ul>
                                            </div>
                                            
                                            <button type="button" class="btn btn-sm btn-danger" onclick="huyDonHang('@item.MaDH')" title="Hủy đơn">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
function capNhatTrangThai(maDH, trangThai) {
    if (!confirm(`Bạn có chắc muốn cập nhật trạng thái đơn hàng ${maDH} thành '${trangThai}'?`)) {
        return;
    }

    fetch('@Url.Action("CapNhatTrangThai", "DonHang")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `id=${maDH}&trangThai=${encodeURIComponent(trangThai)}`
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('Lỗi: ' + data.message);
        }
    })
    .catch(error => {
        alert('Lỗi: ' + error);
    });
}

function huyDonHang(maDH) {
    if (!confirm(`Bạn có chắc muốn HỦY đơn hàng ${maDH}?\n\nLưu ý: Đơn hàng đã hủy không thể khôi phục!`)) {
        return;
    }

    fetch('@Url.Action("HuyDonHang", "DonHang")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `id=${maDH}`
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('Lỗi: ' + data.message);
        }
    })
    .catch(error => {
        alert('Lỗi: ' + error);
    });
}
</script>
