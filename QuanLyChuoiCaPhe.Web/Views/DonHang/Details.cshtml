@using QuanLyChuoiCaPhe.Web.Models
@model DonHang
@{
    ViewData["Title"] = "Chi tiết Đơn hàng";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-receipt-cutoff"></i> Chi tiết Đơn hàng #@Model.MaDH</h2>
        <div>
            <button onclick="window.print()" class="btn btn-secondary">
                <i class="bi bi-printer"></i> In hóa đơn
            </button>
            <a asp-action="Index" class="btn btn-coffee">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-coffee text-white">
                    <h5><i class="bi bi-info-circle"></i> Thông tin đơn hàng</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <th width="40%">Mã đơn hàng:</th>
                            <td><strong>@Model.MaDH</strong></td>
                        </tr>
                        <tr>
                            <th>Chi nhánh:</th>
                            <td>@Model.ChiNhanh.TenChiNhanh</td>
                        </tr>
                        <tr>
                            <th>Nhân viên:</th>
                            <td>@Model.ThongTinNhanVien.HoTenNV</td>
                        </tr>
                        <tr>
                            <th>Khách hàng:</th>
                            <td>@(Model.KhachHang?.TenKH ?? "Khách vãng lai")</td>
                        </tr>
                        <tr>
                            <th>Phương thức TT:</th>
                            <td><span class="badge bg-info">@Model.PhuongThucThanhToan</span></td>
                        </tr>
                        <tr>
                            <th>Ngày tạo:</th>
                            <td>@Model.NgayTao.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        </tr>
                        <tr>
                            <th>Trạng thái:</th>
                            <td><span class="badge bg-success">@Model.TrangThai</span></td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-coffee text-white">
                    <h5><i class="bi bi-cash-coin"></i> Thanh toán</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <th width="40%">Tổng tiền:</th>
                            <td class="text-end">@Model.TongTien.ToString("N0") đ</td>
                        </tr>
                        <tr>
                            <th>Giảm giá:</th>
                            <td class="text-end text-danger">-@Model.GiamGia.ToString("N0") đ</td>
                        </tr>
                        <tr class="border-top">
                            <th><h5>Thành tiền:</h5></th>
                            <td class="text-end"><h5 class="text-success">@((Model.TongTien - Model.GiamGia).ToString("N0")) đ</h5></td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-coffee text-white">
            <h5><i class="bi bi-list-ul"></i> Chi tiết sản phẩm</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>STT</th>
                            <th>Sản phẩm</th>
                            <th>Size</th>
                            <th>Số lượng</th>
                            <th>Đơn giá</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int stt = 1;
                        }
                        @foreach (var item in Model.ChiTietDonHangs)
                        {
                            <tr>
                                <td>@stt</td>
                                <td>
                                    <strong>@item.BienTheSanPham.SanPham.TenSanPham</strong>
                                    <br />
                                    <small class="text-muted">@item.MaBienThe</small>
                                </td>
                                <td><span class="badge bg-secondary">@item.BienTheSanPham.Size</span></td>
                                <td class="text-center">@item.SoLuong</td>
                                <td class="text-end">@item.DonGia.ToString("N0") đ</td>
                                <td class="text-end"><strong>@item.ThanhTien.ToString("N0") đ</strong></td>
                            </tr>
                            stt++;
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th colspan="5" class="text-end">Tổng cộng:</th>
                            <th class="text-end">@Model.TongTien.ToString("N0") đ</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
