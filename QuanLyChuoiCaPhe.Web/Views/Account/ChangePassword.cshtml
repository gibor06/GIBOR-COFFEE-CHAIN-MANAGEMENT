@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container-fluid p-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-coffee text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-key"></i> Đổi mật khẩu
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i>
                        Bạn đang đổi mật khẩu cho tài khoản: <strong>@ViewBag.TenDangNhap</strong>
                    </div>

                    <form asp-action="ChangePassword" method="post">
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu cũ <span class="text-danger">*</span></label>
                            <input type="password" name="oldPassword" id="oldPassword" class="form-control" placeholder="Nhập mật khẩu hiện tại" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới <span class="text-danger">*</span></label>
                            <input type="password" name="newPassword" id="newPassword" class="form-control" placeholder="Nhập mật khẩu mới" required />
                            <small class="text-muted">Mật khẩu phải có ít nhất 6 ký tự</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                            <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" required />
                            <span id="confirmPasswordError" class="text-danger"></span>
                        </div>

                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i>
                            <strong>Lưu ý:</strong>
                            <ul class="mb-0 mt-2">
                                <li>Mật khẩu mới phải khác mật khẩu cũ</li>
                                <li>Mật khẩu nên có ít nhất 6 ký tự</li>
                                <li>Nên kết hợp chữ hoa, chữ thường và số</li>
                                <li>Sau khi đổi mật khẩu, bạn sẽ phải đăng nhập lại</li>
                            </ul>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-coffee">
                                <i class="bi bi-key"></i> Đổi mật khẩu
                            </button>
                            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelector('form').addEventListener('submit', function(e) {
            const oldPassword = document.getElementById('oldPassword').value;
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const errorSpan = document.getElementById('confirmPasswordError');

            // Kiểm tra mật khẩu mới và xác nhận khớp
            if (newPassword !== confirmPassword) {
                e.preventDefault();
                errorSpan.textContent = 'Mật khẩu mới và xác nhận không khớp!';
                return false;
            }

            // Kiểm tra độ dài
            if (newPassword.length < 6) {
                e.preventDefault();
                errorSpan.textContent = 'Mật khẩu mới phải có ít nhất 6 ký tự!';
                return false;
            }

            // Kiểm tra mật khẩu mới khác mật khẩu cũ
            if (oldPassword === newPassword) {
                e.preventDefault();
                errorSpan.textContent = 'Mật khẩu mới phải khác mật khẩu cũ!';
                return false;
            }

            errorSpan.textContent = '';
        });

        // Clear error on input
        document.getElementById('confirmPassword').addEventListener('input', function() {
            document.getElementById('confirmPasswordError').textContent = '';
        });

        document.getElementById('newPassword').addEventListener('input', function() {
            document.getElementById('confirmPasswordError').textContent = '';
        });
    </script>
}
