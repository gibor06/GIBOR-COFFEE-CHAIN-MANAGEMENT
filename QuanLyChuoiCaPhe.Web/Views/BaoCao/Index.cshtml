@using QuanLyChuoiCaPhe.Web.Services
@{
    ViewData["Title"] = "Báo cáo";
}

<div class="container-fluid p-4">
    <h2><i class="bi bi-bar-chart"></i> Báo cáo Tổng hợp</h2>

    <div class="row g-3 mt-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-coffee text-white">
                    <h5><i class="bi bi-shop"></i> Doanh thu theo Chi nhánh</h5>
                </div>
                <div class="card-body">
                    <canvas id="doanhThuChiNhanhChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-coffee text-white">
                    <h5><i class="bi bi-calendar-week"></i> Doanh thu 7 ngày gần đây</h5>
                </div>
                <div class="card-body">
                    <canvas id="doanhThuNgayChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-coffee text-white">
                    <h5><i class="bi bi-trophy"></i> Top 10 Sản phẩm bán chạy</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>STT</th>
                                    <th>Sản phẩm</th>
                                    <th>Size</th>
                                    <th>SL bán</th>
                                    <th>Doanh thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int stt = 1;
                                    var topSanPham = ViewBag.TopSanPham as List<SanPhamBanChay>;
                                }
                                @if (topSanPham != null && topSanPham.Any())
                                {
                                    @foreach (var item in topSanPham)
                                    {
                                        <tr>
                                            <td>@stt</td>
                                            <td>
                                                <strong>@item.TenSanPham</strong>
                                                <br />
                                                <small class="text-muted">@item.MaBienThe</small>
                                            </td>
                                            <td><span class="badge bg-secondary">@item.Size</span></td>
                                            <td class="text-center"><strong>@item.SoLuongBan</strong></td>
                                            <td class="text-success">@item.DoanhThu.ToString("N0") đ</td>
                                        </tr>
                                        stt++;
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted">Chưa có dữ liệu</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-coffee text-white">
                    <h5><i class="bi bi-star"></i> Top 10 Khách hàng thân thiết</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>STT</th>
                                    <th>Tên khách hàng</th>
                                    <th>SĐT</th>
                                    <th>Điểm tích lũy</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    stt = 1;
                                    var topKhachHang = ViewBag.TopKhachHang as List<KhachHangThanThiet>;
                                }
                                @if (topKhachHang != null && topKhachHang.Any())
                                {
                                    @foreach (var item in topKhachHang)
                                    {
                                        <tr>
                                            <td>@stt</td>
                                            <td><strong>@item.TenKH</strong></td>
                                            <td>@item.SoDienThoai</td>
                                            <td><span class="badge bg-warning">@item.DiemTichLuy điểm</span></td>
                                        </tr>
                                        stt++;
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted">Chưa có dữ liệu</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-coffee text-white">
                    <h5><i class="bi bi-clock-history"></i> Nhật ký Hệ thống (50 gần nhất)</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-sm table-hover">
                            <thead class="sticky-top bg-light">
                                <tr>
                                    <th>Thời gian</th>
                                    <th>Tài khoản</th>
                                    <th>Hành động</th>
                                    <th>Bảng</th>
                                    <th>SL tác động</th>
                                    <th>Nội dung</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var nhatKy = ViewBag.NhatKy as List<DuLieuHeThong>;
                                }
                                @if (nhatKy != null && nhatKy.Any())
                                {
                                    @foreach (var item in nhatKy)
                                    {
                                        <tr>
                                            <td>@item.ThoiGian.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                            <td>@item.HeThongTaiKhoan?.TenDangNhap</td>
                                            <td><span class="badge bg-info">@item.HanhDong</span></td>
                                            <td>@item.TenBang</td>
                                            <td>@item.SoLuongTacDong</td>
                                            <td>@item.NoiDung</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted">Chưa có nhật ký</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Doanh thu theo chi nhánh
        const doanhThuChiNhanh = @Html.Raw(Json.Serialize(ViewBag.DoanhThuTheoChiNhanh ?? new Dictionary<string, decimal>()));
        
        new Chart(document.getElementById('doanhThuChiNhanhChart'), {
            type: 'bar',
            data: {
                labels: Object.keys(doanhThuChiNhanh),
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: Object.values(doanhThuChiNhanh),
                    backgroundColor: '#8B4513',
                    borderColor: '#6F3609',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return value.toLocaleString('vi-VN') + ' đ';
                            }
                        }
                    }
                }
            }
        });

        // Doanh thu theo ngày
        const doanhThuNgay = @Html.Raw(Json.Serialize(ViewBag.DoanhThuTheoNgay ?? new List<object>()));
        
        new Chart(document.getElementById('doanhThuNgayChart'), {
            type: 'line',
            data: {
                labels: doanhThuNgay.map(d => new Date(d.ngay).toLocaleDateString('vi-VN')),
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: doanhThuNgay.map(d => d.doanhThu),
                    backgroundColor: 'rgba(139, 69, 19, 0.2)',
                    borderColor: '#8B4513',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return value.toLocaleString('vi-VN') + ' đ';
                            }
                        }
                    }
                }
            }
        });
    </script>
}
