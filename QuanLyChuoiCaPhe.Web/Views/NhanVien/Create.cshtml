@model ThongTinNhanVien
@{
    ViewData["Title"] = "Thêm Nhân viên";
}

<div class="container-fluid p-4">
    <h2><i class="bi bi-plus-circle"></i> Thêm Nhân viên</h2>

    <div class="card mt-3">
        <div class="card-body">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }
            
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <strong>Có lỗi xảy ra:</strong>
                    <ul class="mb-0">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }
            
            <form asp-action="Create" method="post" novalidate>
                @Html.AntiForgeryToken()
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="HoTenNV" class="form-label">Họ tên <span class="text-danger">*</span></label>
                        <input asp-for="HoTenNV" class="form-control" required />
                        <span asp-validation-for="HoTenNV" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="LoaiNV" class="form-label">Loại nhân viên <span class="text-danger">*</span></label>
                        <select asp-for="LoaiNV" class="form-select" required>
                            <option value="">-- Chọn loại --</option>
                            <option value="1">Fulltime</option>
                            <option value="2">Parttime</option>
                        </select>
                        <span asp-validation-for="LoaiNV" class="text-danger"></span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="MaChucVu" class="form-label">Chức vụ <span class="text-danger">*</span></label>
                        <select asp-for="MaChucVu" class="form-select" asp-items="ViewBag.ChucVus" required>
                            <option value="">-- Chọn chức vụ --</option>
                        </select>
                        <span asp-validation-for="MaChucVu" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="MaChiNhanh" class="form-label">Chi nhánh <span class="text-danger">*</span></label>
                        <select asp-for="MaChiNhanh" class="form-select" asp-items="ViewBag.ChiNhanhs" required>
                            <option value="">-- Chọn chi nhánh --</option>
                        </select>
                        <span asp-validation-for="MaChiNhanh" class="text-danger"></span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SoDienThoai" class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                        <input asp-for="SoDienThoai" class="form-control" maxlength="10" pattern="[0-9]{10}" placeholder="0123456789" required />
                        <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="SoCanCuoc" class="form-label">Số căn cước <span class="text-danger">*</span></label>
                        <input asp-for="SoCanCuoc" class="form-control" maxlength="12" pattern="[0-9]{12}" placeholder="123456789012" required />
                        <span asp-validation-for="SoCanCuoc" class="text-danger"></span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="example@email.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="NgayVaoLam" class="form-label">Ngày vào làm <span class="text-danger">*</span></label>
                        <input asp-for="NgayVaoLam" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                        <span asp-validation-for="NgayVaoLam" class="text-danger"></span>
                    </div>
                </div>
                
                <div class="mt-3">
                    <button type="submit" class="btn btn-coffee">
                        <i class="bi bi-save"></i> Lưu
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* Tạm thời comment validation scripts do CDN bị chặn
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
*@