@model HeThongTaiKhoan
@{
    ViewData["Title"] = "Chỉnh sửa tài khoản";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-pencil"></i> Chỉnh sửa tài khoản</h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="MaTK" />
                <input type="hidden" asp-for="MatKhauHash" />
                <input type="hidden" asp-for="NgayTao" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Mã tài khoản</label>
                            <input type="text" class="form-control" value="@Model.MaTK" disabled />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="TenDangNhap" class="form-label">Tên đăng nhập <span class="text-danger">*</span></label>
                            <input asp-for="TenDangNhap" class="form-control" />
                            <span asp-validation-for="TenDangNhap" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="VaiTro" class="form-label">Vai trò <span class="text-danger">*</span></label>
                            <select asp-for="VaiTro" class="form-select">
                                <option value="">-- Chọn vai trò --</option>
                                <option value="ADMIN">ADMIN</option>
                                <option value="QUAN_LY">QUAN_LY</option>
                                <option value="NHAN_VIEN">NHAN_VIEN</option>
                                <option value="KHO">KHO</option>
                                <option value="KE_TOAN">KE_TOAN</option>
                            </select>
                            <span asp-validation-for="VaiTro" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Ngày tạo</label>
                            <input type="text" class="form-control" value="@Model.NgayTao.ToString("dd/MM/yyyy HH:mm")" disabled />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="TrangThai" class="form-check-input" type="checkbox" />
                                <label asp-for="TrangThai" class="form-check-label">
                                    Kích hoạt tài khoản
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> 
                    Để thay đổi mật khẩu, vui lòng sử dụng chức năng "Đặt lại mật khẩu".
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-coffee">
                        <i class="bi bi-save"></i> Cập nhật
                    </button>
                    <a asp-action="ResetPassword" asp-route-id="@Model.MaTK" class="btn btn-warning">
                        <i class="bi bi-key"></i> Đặt lại mật khẩu
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
