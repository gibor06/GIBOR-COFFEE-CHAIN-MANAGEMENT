@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-key"></i> Đặt lại mật khẩu</h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Cảnh báo:</strong> Bạn đang đặt lại mật khẩu cho tài khoản <strong>@ViewBag.TenDangNhap</strong>
            </div>

            <form asp-action="ResetPassword" method="post">
                <input type="hidden" name="id" value="@ViewBag.MaTK" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới <span class="text-danger">*</span></label>
                            <input type="password" name="newPassword" id="newPassword" class="form-control" placeholder="Nhập mật khẩu mới" required />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                            <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" required />
                            <span id="confirmPasswordError" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> 
                    <strong>Lưu ý:</strong>
                    <ul class="mb-0 mt-2">
                        <li>Mật khẩu nên có ít nhất 6 ký tự</li>
                        <li>Nên kết hợp chữ hoa, chữ thường và số</li>
                        <li>Người dùng nên đổi mật khẩu sau lần đăng nhập đầu tiên</li>
                    </ul>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-key"></i> Đặt lại mật khẩu
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelector('form').addEventListener('submit', function(e) {
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const errorSpan = document.getElementById('confirmPasswordError');

            if (newPassword !== confirmPassword) {
                e.preventDefault();
                errorSpan.textContent = 'Mật khẩu xác nhận không khớp!';
                return false;
            }

            if (newPassword.length < 6) {
                e.preventDefault();
                errorSpan.textContent = 'Mật khẩu phải có ít nhất 6 ký tự!';
                return false;
            }

            errorSpan.textContent = '';
        });

        // Clear error on input
        document.getElementById('confirmPassword').addEventListener('input', function() {
            document.getElementById('confirmPasswordError').textContent = '';
        });
    </script>
}
